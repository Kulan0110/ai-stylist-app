# Copy this file to .env and fill in your keys.
# Never commit .env to git — it is listed in .gitignore.

# ─── Claude (Anthropic) API ───────────────────────────────────────────────────
# Get key: console.anthropic.com → API Keys
# Free tier: $5 credit on sign-up, Haiku model is the cheapest (~$0.001/call)
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-api03-...

# ─── HuggingFace Inference API ────────────────────────────────────────────────
# Get token: huggingface.co/settings/tokens → New token (read permission)
# Used for: Cartoon Avatar SDXL image generation (free with token)
# Leave empty to disable the Cartoon Avatar feature
EXPO_PUBLIC_HF_TOKEN=hf_...
